{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Publish OEPLSample Linux x64",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "publish",
        "OEPLSample/OEPLSample.csproj",
        "-c",
        "Release",
        "-r",
        "linux-x64",
        "--self-contained",
        "true",
        "-p:PublishSingleFile=true"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": "$msCompile"
    }
  ]
}